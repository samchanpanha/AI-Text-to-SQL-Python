# ── App Environment ──
APP_ENV=development
DEBUG=true

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=text            # text | json
LOG_OUTPUT=console         # console | file | both
LOG_FILE=logs/app.log      # path when OUTPUT=file or both
LOG_MAX_BYTES=10485760     # 10MB per log file
LOG_BACKUP_COUNT=5         # keep 5 rotated files
LOG_DB_ENABLED=true        # persist logs to database
LOG_DB_RETENTION_DAYS=30   # auto-clean logs older than N days
LOG_LLM_CALLS=true         # log all LLM prompt/response pairs

# ── MySQL ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=changeme
DB_NAME=text_to_sql

# ── OpenAI ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_CHEAP=gpt-4o-mini

# ── SMTP ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_DEFAULT_FROM=Text2SQL <noreply@example.com>

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── n8n Integration ──
N8N_WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=changeme-n8n-key-min-32-chars!!
N8N_APP_URL=http://app:8000

# ── Security ──
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5678
RATE_LIMIT_PER_MINUTE=60

# ── Default Admin (auto-created on first run) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
